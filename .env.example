# ─── AI (MiniMax, Anthropic-compatible) ────────────────────────────────────
# If unset, the AI client falls back to deterministic mocks.
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_MODEL=MiniMax-M3

# ─── SQLite (local database) ───────────────────────────────────────────────
# KF_DB_PATH — path to the SQLite database file.
# Default: ./data/forest.db (relative to project root)
KF_DB_PATH=./data/forest.db

# ─── App ───────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
