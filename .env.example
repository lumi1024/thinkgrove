# ─── AI Provider ────────────────────────────────────────────────────────────
# 可选值: minimax (默认) | openai | anthropic | mock
# 留空或不设 = minimax
TG_AI_PROVIDER=minimax

# MiniMax (Anthropic-compatible API)
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_MODEL=MiniMax-M3

# OpenAI (Chat Completions API)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Anthropic (Messages API)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── SQLite ─────────────────────────────────────────────────────────────────
# 留空使用默认路径 data/forest.db
KF_DB_PATH=

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Development ─────────────────────────────────────────────────────────────
# Set to "true" to disable HMR (useful for debugging or slow networks)
# DISABLE_HMR=false

# ─── External Agents ─────────────────────────────────────────────────────────
# OpenClaw (WebSocket gateway, port 18789)
OPENCLAW_ENDPOINT=ws://127.0.0.1:18789
OPENCLAW_DEVICE_TOKEN=
OPENCLAW_DEVICE_ID=
OPENCLAW_PUBLIC_KEY=
OPENCLAW_PRIVATE_KEY=

# Hermes (HTTP API server, port 8642)
HERMES_ENDPOINT=http://127.0.0.1:8642
HERMES_API_KEY=
